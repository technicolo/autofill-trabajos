{
  "manifest_version": 3,
  "name": "el autofill-inador",
  "version": "1.1.0",
  "description": "Rellena formularios de aplicaciones laborales de forma semiautomática.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"], 
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ]
}
