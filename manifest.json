{
  "manifest_version": 3,
  "name": "Job Autofill Helper",
  "version": "1.0.0",
  "description": "Rellena formularios de aplicaciones laborales de forma semiautomática.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Job Autofill Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
